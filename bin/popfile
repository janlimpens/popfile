#!/usr/bin/env bash
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if ! command -v carton >/dev/null 2>&1; then
    echo "carton not found. Install it with:"
    echo "  cpan Carton"
    echo "  # or: curl -L https://cpanmin.us | perl - Carton"
    exit 1
fi

if [ ! -d "$ROOT/local" ]; then
    echo "Installing dependencies (first run)..."
    cd "$ROOT" && carton install
fi

if [ -d "$ROOT/ui" ]; then
    if [ ! -d "$ROOT/ui/node_modules" ]; then
        echo "Installing UI dependencies..."
        cd "$ROOT/ui" && npm install
    fi
    if [ "$ROOT/ui/src" -nt "$ROOT/public/assets" ]; then
        echo "Building UI..."
        cd "$ROOT/ui" && npm run build
    fi
fi

exec carton exec -- perl "$ROOT/script/popfile" "$@"
